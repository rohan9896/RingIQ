# RingIQ local demo environment
RINGIQ_API_BASE_URL=http://127.0.0.1:8000

# LiveKit
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_AGENT_NAME=ringiq-demo-agent

# LiveKit SIP outbound trunk
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxx
LIVEKIT_WAIT_UNTIL_ANSWERED=false
LIVEKIT_SIP_PARTICIPANT_IDENTITY=phone_user
LIVEKIT_SIP_PARTICIPANT_NAME=Demo Lead
LIVEKIT_CALL_TIMEOUT_SECONDS=30
LIVEKIT_PREEMPTIVE_TTS=true

# Deepgram STT
DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_MODEL=flux-general-multi
DEEPGRAM_LANGUAGE_HINTS=en,hi
DEEPGRAM_EAGER_EOT_THRESHOLD=0.4
DEEPGRAM_EOT_THRESHOLD=0.65
DEEPGRAM_EOT_TIMEOUT_MS=2000

# Groq LLM
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TEMPERATURE=0.4

# Sarvam TTS
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_TARGET_LANGUAGE_CODE=hi-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=ashutosh
SARVAM_TTS_SAMPLE_RATE=16000
SARVAM_TTS_PACE=1.0
SARVAM_TTS_MIN_BUFFER_SIZE=30
SARVAM_TTS_MAX_CHUNK_LENGTH=100
SARVAM_TTS_OUTPUT_AUDIO_CODEC=linear16
