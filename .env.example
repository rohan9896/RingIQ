# RingIQ local demo environment
RINGIQ_API_BASE_URL=http://127.0.0.1:8000
RINGIQ_INTERNAL_API_KEY=replace-with-a-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql+asyncpg://ringiq:ringiq@127.0.0.1:5432/ringiq
TEST_DATABASE_URL=postgresql+asyncpg://ringiq:ringiq@127.0.0.1:5432/ringiq_test

# Clerk backend authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----"
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://localhost:3001

# LiveKit
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_AGENT_NAME=ringiq-demo-agent

# LiveKit SIP outbound trunk
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxx
LIVEKIT_WAIT_UNTIL_ANSWERED=false
LIVEKIT_SIP_PARTICIPANT_IDENTITY=phone_user
LIVEKIT_SIP_PARTICIPANT_NAME=Demo Lead
LIVEKIT_CALL_TIMEOUT_SECONDS=30
LIVEKIT_AGENT_READY_TIMEOUT_SECONDS=45
LIVEKIT_SIP_PARTICIPANT_WAIT_TIMEOUT_SECONDS=60
LIVEKIT_PREEMPTIVE_TTS=true
LIVEKIT_CALL_IDLE_TIMEOUT_SECONDS=15
LIVEKIT_CALL_MAX_DURATION_SECONDS=180

# LiveKit audio recording (optional; disabled until storage is configured)
LIVEKIT_RECORDING_ENABLED=false
LIVEKIT_RECORDING_S3_BUCKET=your-recordings-bucket
LIVEKIT_RECORDING_S3_REGION=ap-south-1
LIVEKIT_RECORDING_S3_ACCESS_KEY=your-storage-access-key
LIVEKIT_RECORDING_S3_SECRET=your-storage-secret
LIVEKIT_RECORDING_S3_ENDPOINT=
LIVEKIT_RECORDING_S3_FORCE_PATH_STYLE=false
LIVEKIT_RECORDING_PATH_PREFIX=ringiq/recordings
LIVEKIT_RECORDING_PUBLIC_BASE_URL=https://recordings.example.com
LIVEKIT_RECORDING_FINALIZE_TIMEOUT_SECONDS=30
LIVEKIT_RECORDING_URL_EXPIRY_SECONDS=900

# Deepgram STT
DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_MODEL=flux-general-multi
DEEPGRAM_LANGUAGE_HINTS=en,hi
DEEPGRAM_EAGER_EOT_THRESHOLD=0.4
DEEPGRAM_EOT_THRESHOLD=0.65
DEEPGRAM_EOT_TIMEOUT_MS=1200

# Groq LLM
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TEMPERATURE=0.4
GROQ_REASONING_EFFORT=low
GROQ_MAX_COMPLETION_TOKENS=256

# Sarvam TTS
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_TARGET_LANGUAGE_CODE=hi-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=ashutosh
SARVAM_TTS_SAMPLE_RATE=16000
SARVAM_TTS_PACE=1.0
SARVAM_TTS_MIN_BUFFER_SIZE=30
SARVAM_TTS_MAX_CHUNK_LENGTH=100
SARVAM_TTS_OUTPUT_AUDIO_CODEC=linear16
